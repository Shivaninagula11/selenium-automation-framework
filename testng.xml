<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Framework Test Suite"
       verbose="1"
       parallel="methods"
       thread-count="3">

    <listeners>
        <listener class-name="com.automationframework.utils.ExtentReportManager"/>
    </listeners>

    <test name="Smoke Tests - Chrome">
    <parameter name="browser" value="chrome"/>
    <classes>
        <class name="com.automationframework.tests.LoginTest">
            <methods>
                <include name="testSuccessfulLogin"/>
            </methods>
        </class>
    </classes>
</test>

    <test name="Regression Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.automationframework.tests.LoginTest"/>
        </classes>
    </test>

</suite>